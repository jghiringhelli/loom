# Loom BIOISO Colony — Environment Variables
#
# Copy this file to .env for local Docker runs.
# In Railway: set these as Service Variables in the dashboard (never commit .env).
#
# Required for Tier 3 (Mammal Brain) synthesis:
CLAUDE_API_KEY=sk-ant-...

# Path to the SQLite signal store.
# Railway: set to /data/bioiso.db (mounted volume).
# Local: use ./bioiso.db or :memory: for ephemeral testing.
DB_PATH=/data/bioiso.db

# Orchestrator tick interval in milliseconds.
# 5000 = 5 second ticks (good default for research experiments).
# 1000 = 1 second ticks (aggressive; higher CPU, faster evolution).
TICK_MS=5000

# Ollama base URL for Tier 2 (Ganglion) local LLM synthesis.
# Leave empty to skip Tier 2 and escalate directly to Claude (Tier 3).
# Example: http://host.docker.internal:11434
OLLAMA_BASE_URL=

# Rust log level for the daemon process.
# Values: error | warn | info | debug | trace
RUST_LOG=info
