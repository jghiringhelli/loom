# ── Claim 2: Safe division — non-zero divisor ────────────────────────────────

module SafeDivision

  # {divisor != 0} safe_divide {result * divisor = dividend}
  # Kani: no division-by-zero for all inputs where divisor != 0
  fn safe_divide :: Int -> Int -> Int
    require: divisor != 0
    ensure:  result >= 0
  body
    dividend / divisor
  end

end

# ── Claim 3: Boolean identity — tautological contract ────────────────────────

module BoolIdentity

  # Simple tautology: Kani should prove this trivially (no CBMC counterexample)
  fn bool_id :: Bool -> Bool
    require: flag = true
    ensure:  result = true
  body
    flag
  end

end
