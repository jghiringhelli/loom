/target
# Keep Cargo.lock for the binary crate.
# Uncomment the next line to ignore it (library-only crates):
# Cargo.lock

# IDE / editor artefacts
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db

# Generated corpus outputs
corpus/*.rs

# Generated Rust stubs from `loom compile` on example files
examples/**/*.rs

# Generated Rust output from `loom compile`
out/*.rs

# Standalone compiled binaries (rustc direct output)
*.exe
*.pdb
*.rlib

# Website build artifacts
website/node_modules/
website/dist/
website/.astro/

mutants.out/
mutants.out.old/

experiments/alx/*.rs
experiments/alx/*.exe
experiments/alx/*.pdb
data/btc_ohlc.json

# Nested target/ dirs in sub-crates (root /target rule doesn't cover these)
**/target/

# Runtime artifacts at repo root: SQLite DBs, JSONL run records, run logs.
# Generated by experiments — never commit; if you need replication data,
# put curated subsets under experiments/<name>/evidence/.
/*.db
/*.jsonl
/*.log

# Forgecraft local cache (per-developer, regenerated)
.forgecraft/gates-cache.json
.forgecraft/gates/
