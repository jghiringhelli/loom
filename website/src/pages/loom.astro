---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const targets = [
  { name: 'Rust', icon: '🦀', desc: 'Memory-safe systems code with zero-cost abstractions.' },
  { name: 'TypeScript', icon: '📘', desc: 'Typed interfaces, service contracts, client SDKs.' },
  { name: 'WebAssembly', icon: '⚡', desc: 'Portable binary for browser and edge deployment.' },
  { name: 'OpenAPI 3.0', icon: '📡', desc: 'Machine-readable HTTP API specification.' },
  { name: 'JSON Schema', icon: '{}', desc: 'Validation schemas for data interchange.' },
  { name: 'NeuroML', icon: '🧠', desc: 'Neural network model description (experimental).' },
  { name: 'Mesa', icon: '🔬', desc: 'Agent-based simulation scaffolding (experimental).' },
];

const checkers = [
  'Telos completeness — every entity has a declared goal',
  'Regulation consistency — regulate: targets must be observable',
  'Mortality enforcement — @mortal entities cannot self-replicate indefinitely',
  'Corrigibility — @corrigible requires an external correction mechanism',
  'Autopoiesis closure — autopoietic systems must declare their own boundary',
  'Quorum reachability — quorum thresholds must be statically reachable',
  'Plasticity bounds — synaptic weights must have declared upper/lower bounds',
  'CRISPR targeting — crispr: modifications require a declared target locus',
  'Telomere accounting — telomere: decrements must be bounded',
  'Morphogen stability — morphogen: fields must satisfy reaction-diffusion stability',
];
---

<Base title="Loom" description="An AI-native language that transpiles to Rust, TypeScript, WebAssembly, OpenAPI 3.0, and JSON Schema.">
  <Nav slot="nav" />

  <div style="max-width: 72rem; margin: 0 auto; padding: 3rem 1.5rem;">

    <!-- Header -->
    <div style="max-width: 48rem; margin-bottom: 3.5rem;">
      <p style="color: #7c3aed; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; margin-bottom: 0.75rem;">Language Overview</p>
      <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.02em; color: #e2e8f0; margin-bottom: 1.25rem; line-height: 1.15;">
        Loom
      </h1>
      <p style="font-size: 1.0625rem; color: #94a3b8; line-height: 1.8;">
        Loom is an AI-native functional language that implements Generative Specification. One <code style="color: #c4b5fd; background-color: #1e1e2e; padding: 0.1rem 0.35rem; border-radius: 0.2rem; font-size: 0.875em;">.loom</code> file. Seven emit targets. A compiler that enforces biological constraints before it will generate a single line of Rust.
      </p>
    </div>

    <!-- Real code example -->
    <div style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #e2e8f0; margin-bottom: 1rem;">What Loom Looks Like</h2>
      <pre style="background-color: #1e1e2e; border: 1px solid #2d2d3f; border-radius: 0.75rem; padding: 1.5rem; overflow-x: auto; font-size: 0.875rem; line-height: 1.7;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;">-- A goal-directed trading agent
module ScalpingAgent
describe: "Mean-reversion scalper — Ornstein-Uhlenbeck spread signal"

being ScalpingAgent
  telos: "maximize risk-adjusted pnl"
    bounded_by: pnl_safety_ok
    modifiable_by: operator
  end

  regulate spread_signal
    target: spread
    bounds: (neg_threshold, pos_threshold)
  end

  evolve strategy
    | aggressive when spread > threshold
    | conservative when spread &lt; neg_threshold
    | hold otherwise
  end

  telomere
    limit: max_trades
    on_exhaustion: quiescence
  end
end

fn compute_signal :: Float -&gt; Float -&gt; Float -&gt; Float
  require: sigma &gt; 0.0
  ensure:  result &gt;= neg_3sigma
  ensure:  result &lt;= pos_3sigma
  spread
end
end</code></pre>
    </div>

    <!-- Killer demo -->
    <div style="background: linear-gradient(135deg, #13131a 0%, #1a1030 100%); border: 1px solid #3d2d6f; border-radius: 0.75rem; padding: 2rem; margin-bottom: 4rem;">
      <p style="color: #7c3aed; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; margin-bottom: 0.75rem;">Killer Demo — End-to-End Verified</p>
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.75rem;">Scalping Agent → Rust → Backtest</h2>
      <p style="color: #94a3b8; font-size: 0.9rem; line-height: 1.7; margin-bottom: 1.25rem;">
        One <code style="color: #c4b5fd; background-color: #0a0a0f; padding: 0.1rem 0.3rem; border-radius: 0.2rem; font-size: 0.8em;">scalper.loom</code> file declares the agent. <code style="color: #c4b5fd; background-color: #0a0a0f; padding: 0.1rem 0.3rem; border-radius: 0.2rem; font-size: 0.8em;">loom compile</code> emits Rust. <code style="color: #c4b5fd; background-color: #0a0a0f; padding: 0.1rem 0.3rem; border-radius: 0.2rem; font-size: 0.8em;">rustc</code> compiles it. The backtest runs on synthetic Ornstein-Uhlenbeck price data.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.25rem;">
        {[
          { label: 'Trades', value: '491' },
          { label: 'Win Rate', value: '53.4%' },
          { label: 'Sharpe', value: '0.760' },
          { label: 'PnL', value: '+$30.13' },
        ].map(m => (
          <div style="background-color: #0a0a0f; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; text-align: center;">
            <p style="font-family: 'JetBrains Mono', monospace; font-size: 1.375rem; font-weight: 700; color: #c4b5fd; margin: 0 0 0.25rem 0;">{m.value}</p>
            <p style="font-size: 0.75rem; color: #475569; margin: 0; text-transform: uppercase; letter-spacing: 0.05em;">{m.label}</p>
          </div>
        ))}
      </div>
      <p style="font-size: 0.8rem; color: #475569;">Source: <code style="color: #7c3aed;">experiments/scalper/</code> — both acceptance criteria (Sharpe ≥ 0.5, Win Rate ≥ 50%) verified by the runner.</p>
    </div>

    <!-- What the compiler guarantees -->
    <div style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.5rem;">What the Compiler Guarantees</h2>
      <p style="color: #94a3b8; font-size: 0.9375rem; margin-bottom: 1.5rem; line-height: 1.7;">
        Before emitting any artifact, Loom runs semantic checks drawn from biology. These are not linter warnings — they are hard rejections.
      </p>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
        {checkers.map((c, i) => (
          <li style="display: flex; gap: 1rem; align-items: flex-start; padding: 0.875rem 1.25rem; background-color: #13131a; border: 1px solid #1e1e2e; border-radius: 0.5rem;">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #7c3aed; min-width: 1.5rem; padding-top: 0.1rem;">{String(i + 1).padStart(2, '0')}</span>
            <span style="font-size: 0.9rem; color: #cbd5e1; line-height: 1.6;">{c}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Emit targets -->
    <div style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.5rem;">One Source. Seven Targets.</h2>
      <p style="color: #94a3b8; font-size: 0.9375rem; margin-bottom: 1.5rem;">The Loom compiler derives all of these from a single specification file.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        {targets.map(t => (
          <div style="background-color: #13131a; border: 1px solid #1e1e2e; border-radius: 0.5rem; padding: 1.25rem;">
            <div style="font-size: 1.25rem; margin-bottom: 0.5rem;">{t.icon}</div>
            <p style="font-weight: 600; color: #e2e8f0; margin: 0 0 0.35rem 0; font-size: 0.9375rem;">{t.name}</p>
            <p style="font-size: 0.8125rem; color: #94a3b8; margin: 0; line-height: 1.5;">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- The pipeline -->
    <div style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #e2e8f0; margin-bottom: 1rem;">The Compiler Pipeline</h2>
      <div style="display: flex; gap: 0; overflow-x: auto; padding-bottom: 0.5rem;">
        {['Parse', 'Resolve', 'Check (×10)', 'Emit'].map((stage, i, arr) => (
          <div style="display: flex; align-items: center;">
            <div style="background-color: #13131a; border: 1px solid #1e1e2e; border-radius: 0.5rem; padding: 0.75rem 1.25rem; white-space: nowrap;">
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; color: #c4b5fd;">{stage}</span>
            </div>
            {i < arr.length - 1 && (
              <span style="color: #7c3aed; margin: 0 0.5rem; font-size: 1.25rem;">→</span>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Key constructs -->
    <div style="margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #e2e8f0; margin-bottom: 1rem;">Key Constructs</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">

        <div>
          <p style="font-size: 0.8rem; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; font-weight: 600;">Goal-direction</p>
          <pre style="background-color: #1e1e2e; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; font-size: 0.8125rem; margin: 0;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;">telos: "minimize latency"
  bounded_by: sla_ok
end
@corrigible</code></pre>
        </div>

        <div>
          <p style="font-size: 0.8rem; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; font-weight: 600;">Homeostasis</p>
          <pre style="background-color: #1e1e2e; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; font-size: 0.8125rem; margin: 0;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;">regulate error_rate
  target: rate
  bounds: (min_rate, max_rate)
end</code></pre>
        </div>

        <div>
          <p style="font-size: 0.8rem; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; font-weight: 600;">Contracts</p>
          <pre style="background-color: #1e1e2e; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; font-size: 0.8125rem; margin: 0;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;">fn charge :: Float -&gt; Account
  require: amount &gt; 0.0
  ensure:  result != InvalidAmount
  PaymentResult
end</code></pre>
        </div>

        <div>
          <p style="font-size: 0.8rem; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; font-weight: 600;">Bounded life</p>
          <pre style="background-color: #1e1e2e; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; font-size: 0.8125rem; margin: 0;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;">@mortal
telomere
  limit: 100
  on_exhaustion: apoptosis
end</code></pre>
        </div>

        <div>
          <p style="font-size: 0.8rem; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; font-weight: 600;">Directed evolution</p>
          <pre style="background-color: #1e1e2e; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; font-size: 0.8125rem; margin: 0;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;">evolve strategy
  | aggressive when vol &gt; high
  | conservative when vol &lt; low
  | hold otherwise
end</code></pre>
        </div>

        <div>
          <p style="font-size: 0.8rem; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; font-weight: 600;">Operational closure</p>
          <pre style="background-color: #1e1e2e; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; font-size: 0.8125rem; margin: 0;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;">being Agent
  autopoietic: true
  -- compiler enforces self-production
end</code></pre>
        </div>

      </div>
    </div>

    <!-- Getting started -->
    <div style="background-color: #13131a; border: 1px solid #1e1e2e; border-radius: 0.75rem; padding: 2rem; margin-bottom: 4rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #e2e8f0; margin-bottom: 1rem;">Getting Started</h2>
      <p style="color: #94a3b8; font-size: 0.9375rem; margin-bottom: 1.25rem; line-height: 1.7;">
        Loom is written in Rust. Build from source — Cargo publish coming with v0.2:
      </p>
      <pre style="background-color: #0a0a0f; border: 1px solid #2d2d3f; border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.25rem; font-size: 0.875rem;"><code style="color: #c4b5fd; font-family: 'JetBrains Mono', monospace;"># Clone and build
git clone https://github.com/PragmaWorks/loom
cd loom
cargo build --release

# Compile a .loom file to Rust
./target/release/loom compile my-spec.loom

# Compile to WebAssembly
./target/release/loom compile my-spec.loom --target wasm

# Check only (no output written)
./target/release/loom compile my-spec.loom --check-only</code></pre>
      <p style="color: #475569; font-size: 0.8125rem;">
        Coming soon: <code style="color: #c4b5fd; background-color: #0a0a0f; padding: 0.1rem 0.35rem; border-radius: 0.2rem; font-size: 0.875em;">cargo install loom</code>
      </p>
    </div>

    <p>
      <a href="/gs" style="color: #c4b5fd; font-weight: 500;">Read the GS theory →</a>
      &nbsp;&nbsp;
      <a href="/isomorphisms" style="color: #c4b5fd; font-weight: 500;">See the isomorphisms table →</a>
      &nbsp;&nbsp;
      <a href="/primer" style="color: #c4b5fd; font-weight: 500;">Intellectual lineage →</a>
    </p>

  </div>
</Base>

