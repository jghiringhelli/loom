---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---

<Base title="404 — Not Found">
  <Nav slot="nav" />
  <div style="min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 3rem 1.5rem;">
    <p style="font-family: 'JetBrains Mono', monospace; font-size: 4rem; font-weight: 800; color: #1e1e2e; margin-bottom: 1rem; line-height: 1;">404</p>
    <h1 style="font-size: 1.5rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.75rem;">Specification gap detected</h1>
    <p style="color: #94a3b8; font-size: 0.9375rem; margin-bottom: 2rem; max-width: 30rem; line-height: 1.6;">
      This page does not exist. Unlike a specification gap, this one is harmless.
    </p>
    <a href="/" style="background-color: #7c3aed; color: #fff; font-weight: 600; padding: 0.75rem 1.75rem; border-radius: 0.5rem; font-size: 0.9375rem; text-decoration: none;">
      ← Return to BIOISO
    </a>
  </div>
</Base>
